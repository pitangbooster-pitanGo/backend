@baseUrl = http://localhost:10000/api

@email = eduuardavasconcelos@gmail.com
@password = Java@1973!

@jwtAtivo = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpZCI6MSwiaWF0IjoxNzc3MjQ0MjM5LCJleHAiOjE3Nzk4MzYyMzl9.oWcFdggiFa_U53bvJnlEWYezhpbg7eJMuAWQsGsoB2Q
@jwtEmployee = COLE_AQUI_O_JWT_DO_EMPLOYEE
@jwtInvalido = invalid.token.value

@adminRoleId = 3
@hrRoleId = 4
@leadershipRoleId = 5
@employeeRoleId = 6

@projectId = 1
@institutionalTrackId = 1
@projectTrackId = 2
@employeeUserId = 2
@projectReadingTaskId = 3
@trackAssignmentId = 1
@taskExecutionId = 1

### Login
POST {{baseUrl}}/auth/local
Content-Type: application/json

{
  "identifier": "{{email}}",
  "password": "{{password}}"
}

### /api/me - usuario ativo + token valido
GET {{baseUrl}}/me
Authorization: Bearer {{jwtAtivo}}

### /api/me - sem token
GET {{baseUrl}}/me

### /api/me - token invalido
GET {{baseUrl}}/me
Authorization: Bearer {{jwtInvalido}}

### Listar roles do users-permissions
GET {{baseUrl}}/users-permissions/roles
Authorization: Bearer {{jwtAtivo}}

### Criar usuario admin
POST {{baseUrl}}/users
Content-Type: application/json
Authorization: Bearer {{jwtAtivo}}

{
  "username": "admin.pitango",
  "email": "admin@pitango.local",
  "password": "Admin@123",
  "role": {{adminRoleId}}
}

### Criar usuario hr
POST {{baseUrl}}/users
Content-Type: application/json
Authorization: Bearer {{jwtAtivo}}

{
  "username": "hr.pitango",
  "email": "hr@pitango.local",
  "password": "Hr@12345",
  "role": {{hrRoleId}}
}

### Criar usuario leadership
POST {{baseUrl}}/users
Content-Type: application/json
Authorization: Bearer {{jwtAtivo}}

{
  "username": "leadership.pitango",
  "email": "leadership@pitango.local",
  "password": "Leader@123",
  "role": {{leadershipRoleId}}
}

### Criar usuario employee
POST {{baseUrl}}/users
Content-Type: application/json
Authorization: Bearer {{jwtAtivo}}

{
  "username": "employee.pitango",
  "email": "employee@pitango.local",
  "password": "Employee@123",
  "role": {{employeeRoleId}}
}

### Listar usuarios
GET {{baseUrl}}/users
Authorization: Bearer {{jwtAtivo}}

### Criar projeto Tramontina
POST {{baseUrl}}/projects
Content-Type: application/json
Authorization: Bearer {{jwtAtivo}}

{
  "data": {
    "name": "Projeto Tramontina",
    "description": "Projeto de onboarding tecnico e contextual para novos colaboradores alocados na frente Tramontina.",
    "is_active": true
  }
}

### Criar projeto institucional
POST {{baseUrl}}/projects
Content-Type: application/json
Authorization: Bearer {{jwtAtivo}}

{
  "data": {
    "name": "Projeto Institucional",
    "description": "Projeto base para concentrar trilhas institucionais de onboarding.",
    "is_active": true
  }
}

### Listar projetos
GET {{baseUrl}}/projects?populate=tracks
Authorization: Bearer {{jwtAtivo}}

### Criar trilha institucional
POST {{baseUrl}}/tracks
Content-Type: application/json
Authorization: Bearer {{jwtAtivo}}

{
  "data": {
    "name": "Onboarding Institucional",
    "description": "Trilha inicial com conteudos gerais sobre a empresa, cultura, ferramentas e processos internos.",
    "track_type": "institutional",
    "version": 1,
    "is_active": true
  }
}

### Criar trilha de projeto Tramontina
POST {{baseUrl}}/tracks
Content-Type: application/json
Authorization: Bearer {{jwtAtivo}}

{
  "data": {
    "name": "Onboarding Projeto Tramontina",
    "description": "Trilha com atividades especificas para entendimento do contexto, arquitetura e fluxo de trabalho do projeto Tramontina.",
    "track_type": "project",
    "version": 1,
    "is_active": true,
    "projects": [{{projectId}}]
  }
}

### Listar trilhas com tarefas e projetos
GET {{baseUrl}}/tracks?populate=*
Authorization: Bearer {{jwtAtivo}}

### Criar tarefa institucional 1
POST {{baseUrl}}/tasks
Content-Type: application/json
Authorization: Bearer {{jwtAtivo}}

{
  "data": {
    "title": "Ler documentacao institucional",
    "description": "Ler o material de onboarding institucional e entender o funcionamento geral da empresa.",
    "order_index": 1,
    "is_required": true,
    "requires_evidence": false,
    "requires_manual_approval": false,
    "action_type": "reading",
    "is_active": true,
    "track": {{institutionalTrackId}}
  }
}

### Criar tarefa institucional 2
POST {{baseUrl}}/tasks
Content-Type: application/json
Authorization: Bearer {{jwtAtivo}}

{
  "data": {
    "title": "Configurar ferramentas de trabalho",
    "description": "Configurar e validar acesso as ferramentas principais usadas no dia a dia.",
    "order_index": 2,
    "is_required": true,
    "requires_evidence": false,
    "requires_manual_approval": false,
    "action_type": "form",
    "is_active": true,
    "track": {{institutionalTrackId}}
  }
}

### Criar tarefa projeto 1
POST {{baseUrl}}/tasks
Content-Type: application/json
Authorization: Bearer {{jwtAtivo}}

{
  "data": {
    "title": "Ler documentacao do projeto",
    "description": "Ler a documentacao funcional e tecnica do projeto Tramontina.",
    "order_index": 1,
    "is_required": true,
    "requires_evidence": false,
    "requires_manual_approval": false,
    "action_type": "reading",
    "is_active": true,
    "track": {{projectTrackId}}
  }
}

### Criar tarefa projeto 2 com dependencia valida
POST {{baseUrl}}/tasks
Content-Type: application/json
Authorization: Bearer {{jwtAtivo}}

{
  "data": {
    "title": "Configurar acessos do projeto",
    "description": "Executar a configuracao inicial apenas apos a leitura da documentacao do projeto.",
    "order_index": 2,
    "is_required": true,
    "requires_evidence": false,
    "requires_manual_approval": false,
    "action_type": "form",
    "is_active": true,
    "track": {{projectTrackId}},
    "depends_on": [{{projectReadingTaskId}}]
  }
}

### Criar tarefa com dependencia invalida em outra trilha
POST {{baseUrl}}/tasks
Content-Type: application/json
Authorization: Bearer {{jwtAtivo}}

{
  "data": {
    "title": "Dependencia invalida",
    "description": "Esta chamada deve falhar porque a dependencia esta em outra trilha.",
    "order_index": 3,
    "is_required": true,
    "requires_evidence": false,
    "requires_manual_approval": false,
    "action_type": "reading",
    "is_active": true,
    "track": {{institutionalTrackId}},
    "depends_on": [{{projectReadingTaskId}}]
  }
}

### Listar tarefas com trilha e dependencias
GET {{baseUrl}}/tasks?populate=*
Authorization: Bearer {{jwtAtivo}}

### Buscar tarefa por id
GET {{baseUrl}}/tasks/{{projectReadingTaskId}}?populate=*
Authorization: Bearer {{jwtAtivo}}

### Criar atribuicao de trilha para colaborador
POST {{baseUrl}}/track-assignments
Content-Type: application/json
Authorization: Bearer {{jwtAtivo}}

{
  "data": {
    "track": {{institutionalTrackId}},
    "user": {{employeeUserId}}
  }
}

### Listar atribuicoes de trilha
GET {{baseUrl}}/track-assignments?populate=*
Authorization: Bearer {{jwtAtivo}}

### Minhas trilhas atribuidas
GET {{baseUrl}}/my-track-assignments?populate=track
Authorization: Bearer {{jwtEmployee}}

### Listar tarefas da minha atribuicao
GET {{baseUrl}}/my-track-assignments/{{trackAssignmentId}}/tasks
Authorization: Bearer {{jwtEmployee}}

### Concluir task execution
POST {{baseUrl}}/task-executions/{{taskExecutionId}}/complete
Content-Type: application/json
Authorization: Bearer {{jwtEmployee}}

### Employee tentando criar atribuicao
POST {{baseUrl}}/track-assignments
Content-Type: application/json
Authorization: Bearer {{jwtEmployee}}

{
  "data": {
    "track": {{institutionalTrackId}},
    "user": {{employeeUserId}}
  }
}
